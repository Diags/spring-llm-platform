# ==== A copier en .env puis remplir ====

# Cle admin LiteLLM (generer : openssl rand -hex 32, prefixer par sk-)
LITELLM_MASTER_KEY=sk-remplacer-moi

# Mot de passe Postgres de LiteLLM
POSTGRES_PASSWORD=changer-moi

# Cle virtuelle du ai-service — a generer APRES le premier demarrage :
#   curl -X POST http://localhost:4000/key/generate \
#     -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{"key_alias":"ai-service","max_budget":100,"budget_duration":"30d"}'
# Pour le tout premier boot, mettre la master key ici puis la remplacer.
AI_SERVICE_VIRTUAL_KEY=sk-remplacer-moi

# ==== Providers (au moins un requis) ====
AZURE_API_KEY=
AZURE_API_BASE=https://mon-instance.openai.azure.com
MISTRAL_API_KEY=
